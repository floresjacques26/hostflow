# ─────────────────────────────────────────────────────────────────────────────
# HostFlow — Production Environment Variables
#
# Copy to your hosting platform's secret management (Railway Variables,
# Fly.io Secrets, Render Environment Groups, etc.)
#
# NEVER commit this file with real values.
# Generate secrets locally, paste them into the platform UI.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Public URL of the frontend (used for CORS and email links)
FRONTEND_URL=https://app.hostflow.com.br

# Public URL of the backend (used in email links and webhook setup instructions)
APP_URL=https://api.hostflow.com.br


# ── Authentication ────────────────────────────────────────────────────────────

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=


# ── Database ──────────────────────────────────────────────────────────────────

# Railway Postgres plugin sets DATABASE_URL automatically.
# Neon / Supabase: copy the asyncpg connection string from the dashboard.
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=


# ── OpenAI ────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini


# ── Stripe ────────────────────────────────────────────────────────────────────

# Use sk_live_... in production (never sk_test_...)
STRIPE_SECRET_KEY=sk_live_...

# Register webhook at: https://dashboard.stripe.com/webhooks
# Endpoint URL: https://api.hostflow.com.br/webhooks/stripe
# Events: checkout.session.completed, customer.subscription.*
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...


# ── Email (Resend) ────────────────────────────────────────────────────────────

RESEND_API_KEY=re_...

# Must be a verified domain in Resend
EMAIL_FROM=HostFlow <noreply@hostflow.com.br>


# ── Gmail OAuth ───────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must exactly match URI registered in Google Cloud Console
GMAIL_REDIRECT_URI=https://api.hostflow.com.br/api/v1/gmail/callback

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: losing this key makes all stored Gmail tokens unreadable.
# Back it up securely.
GMAIL_ENCRYPTION_KEY=

GMAIL_SYNC_MAX_THREADS=30


# ── WhatsApp Business (Meta) ──────────────────────────────────────────────────

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v19.0

# Webhook URL to register in Meta for Developers:
#   https://api.hostflow.com.br/webhooks/whatsapp


# ── File Storage — S3 / Cloudflare R2 ────────────────────────────────────────

# local storage is NOT suitable for production (ephemeral filesystem)
STORAGE_PROVIDER=s3

# Cloudflare R2 example:
#   STORAGE_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
#   STORAGE_S3_REGION=auto
# AWS S3 example:
#   STORAGE_S3_ENDPOINT_URL=  (leave empty)
#   STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=hostflow-media
STORAGE_S3_REGION=auto
STORAGE_S3_ENDPOINT_URL=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# Optional: public CDN base URL (e.g. https://cdn.hostflow.com.br)
# Leave empty to use pre-signed URLs instead
STORAGE_S3_PUBLIC_BASE_URL=


# ── Observability ─────────────────────────────────────────────────────────────

# Sentry DSN — get from https://sentry.io → Project → Settings → Client Keys
# Set to "disabled" to explicitly opt out without triggering a startup warning
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1


# ── Scheduler ─────────────────────────────────────────────────────────────────

# Keep true on your primary instance.
# Set false on any additional replicas to prevent duplicate job execution.
SCHEDULER_ENABLED=true


# ── SLA thresholds ────────────────────────────────────────────────────────────

SLA_OPEN_OVERDUE_HOURS=4
SLA_PENDING_STALE_HOURS=24
