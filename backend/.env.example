# ─────────────────────────────────────────────────────────────────────────────
# HostFlow — Environment Variables
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Lines starting with # are comments.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────

# Set to true for verbose logging and auto-reload
DEBUG=true

# Public URL of the frontend (used for CORS and email links)
# Development: http://localhost:5173
# Production:  https://app.hostflow.com.br
FRONTEND_URL=http://localhost:5173

# Public URL of the backend (used in webhook setup instructions)
# Development: http://localhost:8000  (or ngrok URL when testing webhooks)
# Production:  https://api.hostflow.com.br
APP_URL=http://localhost:8000


# ── Authentication ────────────────────────────────────────────────────────────

# Strong random secret for JWT signing. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret-in-production


# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
#
# Local (bare):   postgresql+asyncpg://postgres:password@localhost:5432/hostflow
# Local (Docker): postgresql+asyncpg://postgres:password@localhost:5432/hostflow
# Railway:        set automatically by Railway plugin
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hostflow


# ── OpenAI ────────────────────────────────────────────────────────────────────

# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use for AI draft generation
# Recommended: gpt-4o-mini (fast + cheap), gpt-4o (higher quality)
OPENAI_MODEL=gpt-4o-mini


# ── Stripe ────────────────────────────────────────────────────────────────────

# Get keys at: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_...

# Get this from Stripe CLI: stripe listen --forward-to localhost:8000/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from your Stripe Dashboard (Products → Prices)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...


# ── Email (Resend) ────────────────────────────────────────────────────────────

# Get your key at: https://resend.com/api-keys
# Leave empty to disable transactional emails in development
RESEND_API_KEY=re_...

# "From" address for transactional emails (must be a verified domain in Resend)
EMAIL_FROM=HostFlow <noreply@hostflow.com.br>


# ── Gmail OAuth ───────────────────────────────────────────────────────────────

# Create credentials at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:8000/api/v1/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must exactly match the URI registered in Google Cloud Console
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/gmail/callback

# Fernet encryption key for storing OAuth tokens at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: losing this key means existing tokens cannot be decrypted.
GMAIL_ENCRYPTION_KEY=

# Max Gmail threads to fetch per sync run per user (tune for API quota)
GMAIL_SYNC_MAX_THREADS=30


# ── WhatsApp Business (Meta) ──────────────────────────────────────────────────

# Permanent System User access token from Meta Business Suite.
# Used as a global fallback. Each user's token is stored encrypted in the DB.
# Leave empty if users provide their own tokens via the Integrations UI.
WHATSAPP_ACCESS_TOKEN=

# App Secret from Meta App Dashboard → Settings → Basic
# Used to verify X-Hub-Signature-256 on incoming webhooks.
# Leave empty to skip signature verification in development.
WHATSAPP_APP_SECRET=

# Meta Graph API version
WHATSAPP_API_VERSION=v19.0


# ── File Storage ─────────────────────────────────────────────────────────────

# Provider: local | s3
# - local: saves files to ./media directory, served at http://localhost:8000/media
# - s3:    uses S3-compatible API (AWS S3 or Cloudflare R2)
STORAGE_PROVIDER=local

# Local storage settings (only used when STORAGE_PROVIDER=local)
STORAGE_LOCAL_ROOT=media
STORAGE_LOCAL_URL_BASE=http://localhost:8000/media

# S3 / Cloudflare R2 settings (only used when STORAGE_PROVIDER=s3)
# For Cloudflare R2:
#   STORAGE_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
#   STORAGE_S3_REGION=auto
# For AWS S3:
#   STORAGE_S3_ENDPOINT_URL=  (leave empty, boto3 uses default)
#   STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=auto
STORAGE_S3_ENDPOINT_URL=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
# Optional: public CDN base URL (e.g. https://cdn.hostflow.com.br)
# Leave empty to use pre-signed URLs instead
STORAGE_S3_PUBLIC_BASE_URL=


# ── Scheduler ─────────────────────────────────────────────────────────────────

# Set to false in test environments to disable background jobs
SCHEDULER_ENABLED=true


# ── SLA thresholds ────────────────────────────────────────────────────────────

# Hours until an open thread is considered overdue
SLA_OPEN_OVERDUE_HOURS=4

# Hours until a pending thread is considered stale
SLA_PENDING_STALE_HOURS=24
